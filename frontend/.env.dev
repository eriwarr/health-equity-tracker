# ------------------------------------------------------------------------------
# DEVELOPMENT SITE ENVIRONMENT
# ------------------------------------------------------------------------------
# Configuration for the "dev" site at dev.healthequitytracker.org using het-infra-test backend

# Deployment context identifier
VITE_DEPLOY_CONTEXT=dev

# API configuration
# Note: VITE_BASE_API_URL is not needed as API calls will be relative to the frontend domain

# Feature flags
VITE_SHOW_CORRELATION_CARD=1
VITE_SHOW_INSIGHT_GENERATION=1
VITE_SHOW_NCI_COUNTY_CANCER=1